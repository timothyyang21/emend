{
  "name": "emend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "go": "bash scripts/sim.sh",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "verify": "bash scripts/verify.sh",
    "verify:shell": "bash scripts/check-shell.sh",
    "record": "bash scripts/record.sh",
    "update": "eas update --branch preview --environment preview --message",
    "export:web": "expo export --platform web",
    "new": "bash scripts/new-project.sh",
    "qr": "bash scripts/qr.sh",
    "deploy:web": "bash scripts/deploy-web.sh",
    "deliver": "bash scripts/deliver.sh",
    "dev:api": "node --experimental-strip-types scripts/dev-api.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@expo-google-fonts/figtree": "^0.4.1",
    "@expo-google-fonts/literata": "^0.4.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/diff-match-patch": "^1.0.36",
    "diff-match-patch": "^1.0.5",
    "expo": "~54.0.35",
    "expo-audio": "~1.1.1",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
